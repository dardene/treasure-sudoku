{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "treasure-sudoku",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["-e", "require('http').createServer((req,res)=>{const fs=require('fs'),path=require('path'),fp=path.join('./beta',req.url==='/'?'/treasure-sudoku-v3.html':req.url);fs.readFile(fp,(e,d)=>{if(e){res.writeHead(404);res.end();}else{const ext=path.extname(fp).slice(1),m={'html':'text/html','mp3':'audio/mpeg','js':'text/javascript','css':'text/css','png':'image/png','jpg':'image/jpeg','jpeg':'image/jpeg','gif':'image/gif','svg':'image/svg+xml','webp':'image/webp','json':'application/json','woff2':'font/woff2'}[ext]||'application/octet-stream';res.writeHead(200,{'Content-Type':m});res.end(d);}});}).listen(3456,()=>console.log('Server running on port 3456'))"],
      "port": 3456
    }
  ]
}
